    roleContent: "\u9002\u5408\u5173\u7CFB\u3001\u9009\u62E9\u3001\u5F53\u4E0B\u72B6\u6001\u4E0E\u672A\u6765\u8D8B\u52BF\u3002\u5979\u4F1A\u628A\u724C\u9762\u3001\u724C\u4F4D\u548C\u4F60\u7684\u95EE\u9898\u8FDE\u63A5\u8D77\u6765,\u7ED9\u51FA\u60C5\u7EEA\u5C42\u9762\u547D\u4E2D\u611F\u4E0E\u53EF\u6267\u884C\u7684\u5C0F\u884C\u52A8\u3002"
