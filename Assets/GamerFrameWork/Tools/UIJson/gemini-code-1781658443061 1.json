                    { "name": "Desc", "type": "Text", "text": "你们的关系有望走向更深的情感连接与相互理解。彼此的吸引力与默契将不断增强，可能发展为稳定而亲密的关系...", "fontSize": 26, "textColor": { "r": 0.7, "g": 0.65, "b": 0.75, "a": 1.0 }, "anchorMin": { "x": 0, "y": 1 }, "anchorMax": { "x": 0, "y": 1 }, "position": { "x": 520, "y": -100 }, "size": { "x": 760, "y": 100 }, "textAlignment": "TopLeft" }
