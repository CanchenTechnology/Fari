{
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "oracle_sentence", "detail", "do", "dont", "full_reading", "chat_prompts", "cta"],
  "properties": {
    "title": { "type": "string", "maxLength": 8 },
    "oracle_sentence": { "type": "string", "maxLength": 36 },
    "detail": { "type": "string" },
    "do": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string", "maxLength": 6 }
    },
    "dont": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string", "maxLength": 6 }
    },
    "full_reading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["core_meaning", "today_meaning", "deeper_reminder", "micro_action"],
      "properties": {
        "core_meaning": { "type": "string" },
        "today_meaning": { "type": "string" },
        "deeper_reminder": { "type": "string" },
        "micro_action": { "type": "string" }
      }
    },
    "chat_prompts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "string", "maxLength": 24 }
    },
    "cta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "action"],
      "properties": {
        "label": { "type": "string", "maxLength": 12 },
        "action": { "type": "string" }
      }
    }
  }
}
