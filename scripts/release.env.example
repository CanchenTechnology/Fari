# Moonly release preparation environment template.
# Copy this file to scripts/release.env, fill real values locally, and keep it out of git.
#
# Example:
#   cp scripts/release.env.example scripts/release.env
#   RELEASE_ENV_FILE=scripts/release.env ./scripts/check-release-env.sh
#   RELEASE_ENV_FILE=scripts/release.env ./scripts/check-android-keystore.sh
#   RELEASE_ENV_FILE=scripts/release.env REPORT_ONLY=1 ./scripts/prepare-release.sh
#   RELEASE_ENV_FILE=scripts/release.env ./scripts/finish-release.sh
#   APPLE_SHARED_SECRET=... GOOGLE_SERVICE_ACCOUNT_JSON_FILE=... ./scripts/finish-release.sh --no-env-file
#
# The final command above forces real release continuation:
# IAP secret setup, Functions deploy, iOS export, Android APK build, and real receipt gate.

# Firebase / network
FIREBASE_PROJECT=fari-app-b2fd2
MOONLY_PROXY=http://[::1]:7897
MOONLY_ALL_PROXY=socks5://127.0.0.1:10808
CURL_MAX_TIME=180

# Release flow switches
REPORT_ONLY=1
RUN_CONFIGURE_GOOGLE_PLAY_GAMES=auto
RUN_IAP_SECRET_SETUP=0
RUN_DEPLOY=0
RUN_BUILDS=0
WAIT_FOR_UNITY_CLOSE=0
UNITY_WAIT_TIMEOUT_SECONDS=600
UNITY_WAIT_POLL_SECONDS=5

# Google Play Games
# Replace with the numeric App ID from Google Play Console when Play Games is enabled.
# Current Google login does not require Play Games. Set this to 1 only when Play Games services are enabled.
REQUIRE_GOOGLE_PLAY_GAMES=0
GOOGLE_PLAY_GAMES_APP_ID=

# Android release signing
# Required because ProjectSettings enables a custom keystore: user.keystore / chenhao.
ANDROID_KEYSTORE_PASS=
ANDROID_KEYALIAS_PASS=

# IAP Functions secrets
# APPLE_SHARED_SECRET comes from App Store Connect subscriptions.
APPLE_SHARED_SECRET=
GOOGLE_PACKAGE_NAME=com.canchentechnology.fari
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=/absolute/path/google-play-service-account.json

# Optional: set these only when you want to write every secret through setup-firebase-secrets.sh.
DEEPSEEK_API_KEY=
VOLC_TTS_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Real sandbox receipt verification
CHECK_IAP_REAL_RECEIPT=0
IAP_SMOKE_MODE=fake
IAP_PRODUCT_ID=moonly.pro.monthly
IAP_STORE=AppleAppStore
IAP_RECEIPT=
