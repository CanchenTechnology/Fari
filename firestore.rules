rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true
          || request.auth.token.role == "admin"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /daily_oracles/{date} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /divination_records/{readingId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /dialog_sessions/{sessionId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /memories/{memoryId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /tomorrow_hooks/{hookId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /friends/{friendId} {
        allow read, delete: if isOwner(uid);
        allow create, update: if isOwner(uid)
          || (signedIn()
            && request.auth.uid == friendId
            && request.resource.data.uid == request.auth.uid);
      }

      match /friend_requests/{requesterUid} {
        allow read, delete: if isOwner(uid);
        allow create, update: if signedIn()
          && request.auth.uid == requesterUid
          && request.resource.data.uid == request.auth.uid;
      }

      match /virtual_friends/{virtualFriendId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /feedback/{feedbackId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /settings/{settingId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /public_profiles/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if isOwner(uid);
    }

    match /app_config/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "new";
      allow read, update, delete: if isAdmin();
    }

    match /quick_reading/{oracleId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /analytics_events/{eventId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
