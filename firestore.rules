rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && (request.auth.token.admin == true
          || request.auth.token.role == "admin"
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    function isAcceptedFriend(ownerUid) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(ownerUid)/friends/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(ownerUid)/friends/$(request.auth.uid)).data.status == "friend";
    }

    function canReadDailyOracleSummary(data) {
      return signedIn()
        && data.summaryOnly == true
        && data.syncEnabled == true
        && (data.visibility == "all_friends" || data.visibility == "real_friends")
        && isAcceptedFriend(data.ownerUid);
    }

    function isRelationshipParticipant(data) {
      return signedIn()
        && (data.initiatorUid == request.auth.uid || data.receiverUid == request.auth.uid);
    }

    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);

      match /daily_oracles/{date} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /divination_records/{readingId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /dialog_sessions/{sessionId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /memories/{memoryId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /tomorrow_hooks/{hookId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /friends/{friendId} {
        allow read, delete: if isOwner(uid)
          || (signedIn() && request.auth.uid == friendId);
        allow create, update: if isOwner(uid)
          || (signedIn()
            && request.auth.uid == friendId
            && request.resource.data.uid == request.auth.uid);
      }

      match /friend_requests/{requesterUid} {
        allow read, delete: if isOwner(uid)
          || (signedIn() && request.auth.uid == requesterUid);
        allow create, update: if signedIn()
          && request.auth.uid == requesterUid
          && request.resource.data.uid == request.auth.uid;
      }

      match /blocked_users/{blockedUid} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /virtual_friends/{virtualFriendId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /feedback/{feedbackId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /settings/{settingId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /public_profiles/{uid} {
      allow read: if true;
      allow create, update, delete: if isOwner(uid);
    }

    match /daily_oracle_summaries/{summaryId} {
      allow read: if isOwner(resource.data.ownerUid) || canReadDailyOracleSummary(resource.data);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.summaryOnly == true;
      allow update: if isOwner(resource.data.ownerUid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.summaryOnly == true;
      allow delete: if isOwner(resource.data.ownerUid);
    }

    match /relationship_divinations/{readingId} {
      allow read: if isRelationshipParticipant(resource.data);
      allow create: if signedIn()
        && request.resource.data.initiatorUid == request.auth.uid
        && request.resource.data.receiverUid is string
        && request.resource.data.status == "invited"
        && request.resource.data.initiatorRevealed == false
        && request.resource.data.receiverRevealed == false
        && isAcceptedFriend(request.resource.data.receiverUid);
      allow update: if isRelationshipParticipant(resource.data)
        && request.resource.data.readingId == resource.data.readingId
        && request.resource.data.initiatorUid == resource.data.initiatorUid
        && request.resource.data.receiverUid == resource.data.receiverUid
        && request.resource.data.cards == resource.data.cards;
      allow delete: if isRelationshipParticipant(resource.data);
    }

    match /app_config/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "new";
      allow read, update, delete: if isAdmin();
    }

    match /quick_reading/{oracleId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /analytics_events/{eventId} {
      allow create: if signedIn();
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
